{
  "name": "@mizchi/moonlight",
  "version": "0.1.0",
  "description": "Lightweight SVG editor like Excalidraw",
  "type": "module",
  "exports": {
    ".": {
      "import": "./js/api.js",
      "types": "./js/api.d.ts"
    }
  },
  "files": [
    "js",
    "_build/js/release/build/api"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "moon:build:compat": "moon build --target js --release && (test -e _build || ln -s target _build) && (test -e target || ln -s _build target)",
    "build:component": "pnpm moon:build:compat && rolldown -c rolldown.config.mjs",
    "build:all": "pnpm moon:build:compat && vite build && rolldown -c rolldown.config.mjs",
    "deploy": "pnpm build:all && wrangler deploy",
    "worker:dev": "pnpm build:all && wrangler dev",
    "example": "npx serve examples -p 3000",
    "test": "playwright test",
    "test:e2e": "playwright test",
    "test:unit": "./scripts/moon-test.sh",
    "test:mbt": "./scripts/moon-test.sh"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "^25.0.3",
    "happy-dom": "^20.0.11",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.57.0",
    "pngjs": "^7.0.0",
    "puppeteer": "^24.34.0",
    "rolldown": "1.0.0-beta.57",
    "tsdown": "^0.18.3",
    "vite": "8.0.0-beta.5",
    "vite-plugin-moonbit": "^0.1.5",
    "vrt": "github:mizchi/vrt",
    "wrangler": "^4.54.0"
  }
}
